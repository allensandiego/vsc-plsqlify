{
  "name": "vsc-plsqlify",
  "publisher": "allensandiego",
  "displayName": "Plsqlify",
  "description": "Premium formatter for Oracle PL/SQL stored procedures and SQL queries.",
  "version": "0.0.3",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/allensandiego/vsc-plsqlify.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onLanguage:plsql",
    "onLanguage:oracle-plsql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "plsql",
        "aliases": [
          "PL/SQL",
          "plsql"
        ],
        "extensions": [
          ".pls",
          ".plb",
          ".pks",
          ".pkb",
          ".plsql"
        ]
      }
    ],
    "configuration": {
      "title": "Oracle PL/SQL Formatter",
      "properties": {
        "plsql.format.keywordCase": {
          "type": "string",
          "enum": [
            "upper",
            "lower",
            "preserve"
          ],
          "default": "upper",
          "description": "Transform Oracle keywords to UPPERCASE, lowercase, or preserve original casing."
        },
        "plsql.format.maxLineLength": {
          "type": "integer",
          "default": 120,
          "description": "Max line length for formatting."
        },
        "plsql.format.commaPosition": {
          "type": "string",
          "enum": [
            "trailing",
            "leading"
          ],
          "default": "trailing",
          "description": "Place commas at the end of formatted lines (trailing) or start of new lines (leading)."
        },
        "plsql.format.wrapComma": {
          "type": "string",
          "enum": [
            "always",
            "never",
            "preserve"
          ],
          "default": "preserve",
          "description": "Line break mode at commas: split items to separate lines (always), join them on a single line (never), or preserve existing line breaks (preserve)."
        },
        "plsql.format.paramsLineLengthLimit": {
          "type": "integer",
          "default": 200,
          "description": "Maximum character length of a subprogram call/declaration parameters list below which it stays on a single line, and above which each parameter wraps to a new line."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
